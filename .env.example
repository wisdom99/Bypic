# Copy this file to `.env.local` and fill in values as needed.
# `.env.local` is gitignored and only used in development.

# --- AI mood-board fabric matcher --------------------------------------------
# Required for the AI mood-board fabric matcher.
# Without this, /api/match falls back to a deterministic heuristic so the demo
# never breaks. Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Dev server stability (macOS) --------------------------------------------
# If `npm run dev` floods the terminal with `Watchpack Error (watcher): EMFILE`
# and routes start returning 404, the OS file-descriptor budget for fs.watch is
# exhausted (often by other watchers / Cursor agents). Polling avoids it:
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=1
